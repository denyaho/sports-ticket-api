{
  "name": "dbdocs",
  "version": "1.2.1",
  "author": "@holistics",
  "bin": {
    "dbdocs": "./bin/run"
  },
  "dependencies": {
    "@dbml/connector": "7.1.2",
    "@dbml/core": "7.1.2",
    "@oclif/core": "1.26.2",
    "@oclif/plugin-help": "6.2.32",
    "axios": "1.15.0",
    "chalk": "^3.0.0",
    "dotenv": "^8.2.0",
    "inquirer": "^12.9.4",
    "netrc-parser": "^3.1.6",
    "open": "^7.0.0",
    "ora": "^4.0.3",
    "remove-markdown": "^0.5.0",
    "update-notifier": "^6.0.2"
  },
  "devDependencies": {
    "oclif": "^4.22.14"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "/bin",
    "/npm-shrinkwrap.json",
    "/oclif.manifest.json",
    "/src"
  ],
  "keywords": [
    "oclif"
  ],
  "license": "MIT",
  "main": "src/index.js",
  "oclif": {
    "additionalHelpFlags": [
      "help"
    ],
    "additionalVersionFlags": [
      "version"
    ],
    "commands": "./src/commands",
    "bin": "dbdocs",
    "plugins": [
      "@oclif/plugin-help"
    ],
    "hooks": {
      "init": [
        "./src/hooks/init/checkUpdate",
        "./src/hooks/init/loadEnv"
      ],
      "prerun": [
        "./src/hooks/prerun/checkVersion"
      ]
    }
  },
  "repository": "holistics/dbdocs",
  "scripts": {
    "postpack": "rm -f oclif.manifest.json",
    "prepack": "oclif manifest",
    "version": "oclif readme && git add README.md"
  }
}
